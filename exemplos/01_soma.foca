inteiro contador;
contador = 0;

enquanto(contador < 10){
    imprima("compilador");
    contador = contador + 1;
}

inteiro i;
inteiro limite;

imprima("Quantas voltas quer dar no laco?");
leia(limite);

imprima("Iniciando a contagem...");

para (i = 0; i < limite; i = i + 2) {
    imprima("Volta atual:");
    imprima(i);
}

imprima("Fim do laco!");
